# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Expo / Metro ────────────────────────────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# ─── Native project (generated by `expo prebuild`, never commit) ─────────────
android/
ios/

# ─── Build outputs ───────────────────────────────────────────────────────────
*.apk
*.aab
*.ipa

# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem

# ─── Signing / certificates ──────────────────────────────────────────────────
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.cer
*.certSigningRequest
*.provisionprofile

# ─── Logs ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Claude Code ─────────────────────────────────────────────────────────────
.claude/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.orig.*
.node_repl_history
